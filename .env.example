# PromptLabs — Environment Configuration
# Copy this file to .env and edit as needed

# LLM Provider: ollama (default, free, local) | openai | gemini
LLM_PROVIDER=ollama

# Model name (must be pulled in Ollama first: ollama pull llama3.2:3b)
LLM_MODEL=llama3.2:3b

# Base URL for the LLM API
LLM_BASE_URL=http://localhost:11434

# Only needed if LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-your-key-here

# Only needed if LLM_PROVIDER=gemini
# GEMINI_API_KEY=your-key-here
